prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: opentelemetry-c-wrapper_dbg
Description: The OpenTelemetry C wrapper library with debugging support enabled.
Version: @VERSION@

Requires:
Libs: -L${libdir} -Wl,--rpath,${libdir} -lopentelemetry-c-wrapper_dbg
Libs.private: @LIBS_PRIVATE@
Cflags: -I${includedir} -DOTELC_DBG_MEM
