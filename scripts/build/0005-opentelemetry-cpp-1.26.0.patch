diff --git a/exporters/otlp/src/otlp_grpc_client.cc b/exporters/otlp/src/otlp_grpc_client.cc
index 9e065bc0..56f697b2 100644
--- a/exporters/otlp/src/otlp_grpc_client.cc
+++ b/exporters/otlp/src/otlp_grpc_client.cc
@@ -708,6 +708,19 @@ bool OtlpGrpcClient::IsShutdown() const noexcept
   return is_shutdown_.load(std::memory_order_acquire);
 }
 
+bool OtlpGrpcClient::MaybeSpawnBackgroundThread() noexcept
+{
+  if (async_data_ && async_data_->channel)
+  {
+    // GetState(true) transitions the channel from IDLE to CONNECTING,
+    // which triggers gRPC internal thread creation, DNS resolution,
+    // TCP handshake, TLS negotiation and HTTP/2 connection setup.
+    async_data_->channel->GetState(true);
+    return true;
+  }
+  return false;
+}
+
 bool OtlpGrpcClient::ForceFlush(
     OPENTELEMETRY_MAYBE_UNUSED std::chrono::microseconds timeout) noexcept
 {
diff --git a/exporters/otlp/src/otlp_grpc_exporter.cc b/exporters/otlp/src/otlp_grpc_exporter.cc
index fa665ed4..396e6ec2 100644
--- a/exporters/otlp/src/otlp_grpc_exporter.cc
+++ b/exporters/otlp/src/otlp_grpc_exporter.cc
@@ -226,6 +226,16 @@ bool OtlpGrpcExporter::isShutdown() const noexcept
   return is_shutdown_;
 }
 
+bool OtlpGrpcExporter::MaybeSpawnBackgroundThread() noexcept
+{
+  std::shared_ptr<OtlpGrpcClient> client = client_;
+  if (!client)
+  {
+    return false;
+  }
+  return client->MaybeSpawnBackgroundThread();
+}
+
 const std::shared_ptr<OtlpGrpcClient> &OtlpGrpcExporter::GetClient() const noexcept
 {
   return client_;
