From 22ec827c6792467fa191cd3779fb2bd0e3049e88 Mon Sep 17 00:00:00 2001
From: Miroslav Zagorac <mzagorac@haproxy.com>
Date: Thu, 7 May 2026 13:19:04 +0200
Subject: [PATCH 1/6] Use system SSL package instead of BoringSSL in gRPC build

Dropped the third_party/boringssl-with-bazel entry from the gRPC submodule
fetch list in both cmake/grpc.cmake (the FetchContent path) and the file
install/cmake/CMakeLists.txt (the ExternalProject_Add path), and instead
forced gRPC_SSL_PROVIDER to "package" so that the gRPC CMake build picked
up an existing SSL library from the host instead of compiling the bundled
copy of the BoringSSL tree.  This trimmed the fetch and build time of the
gRPC dependency and prevented any ABI clashes with other components in the
project that already linked against the system OpenSSL package.
---
 cmake/grpc.cmake             | 2 +-
 install/cmake/CMakeLists.txt | 1 -
 2 files changed, 1 insertion(+), 2 deletions(-)

diff --git a/cmake/grpc.cmake b/cmake/grpc.cmake
index a420ccb..3b0cf2a 100644
--- a/cmake/grpc.cmake
+++ b/cmake/grpc.cmake
@@ -23,7 +23,6 @@ if(NOT gRPC_FOUND)
           "third_party/abseil-cpp"
           "third_party/protobuf"
           "third_party/cares/cares"
-          "third_party/boringssl-with-bazel"
       )
   set(gRPC_PROVIDER "fetch_repository")
 
@@ -38,6 +37,7 @@ if(NOT gRPC_FOUND)
   set(gRPC_BUILD_GRPC_PYTHON_PLUGIN OFF CACHE BOOL "" FORCE)
   set(gRPC_BUILD_GRPC_RUBY_PLUGIN OFF CACHE BOOL "" FORCE)
   set(gRPC_BUILD_GRPCPP_OTEL_PLUGIN OFF CACHE BOOL "" FORCE)
+  set(gRPC_SSL_PROVIDER "package" CACHE STRING "" FORCE)
   set(gRPC_ZLIB_PROVIDER "package" CACHE STRING "" FORCE)
   set(gRPC_RE2_PROVIDER "module"  CACHE STRING "" FORCE)
   set(RE2_BUILD_TESTING OFF CACHE BOOL "" FORCE)
diff --git a/install/cmake/CMakeLists.txt b/install/cmake/CMakeLists.txt
index 39babcf..1e887b8 100644
--- a/install/cmake/CMakeLists.txt
+++ b/install/cmake/CMakeLists.txt
@@ -215,7 +215,6 @@ if(grpc IN_LIST _THIRDPARTY_PACKAGE_LIST)
     GIT_TAG ${grpc_GIT_TAG}
     GIT_SHALLOW ON
     GIT_SUBMODULES "third_party/re2" "third_party/cares/cares"
-                   "third_party/boringssl-with-bazel"
     PREFIX ${CMAKE_BINARY_DIR}/external/grpc
     INSTALL_DIR ${CMAKE_INSTALL_PREFIX}
     CMAKE_ARGS "${CMAKE_OPTIONS}"
-- 
