@@ -1137,6 +1137,12 @@ class OPENTELEMETRY_LOCAL_SYMBOL OtlpFileSystemBackend : public OtlpFileAppender
     return result;
   }
 
+  bool MaybeSpawnBackgroundThread() noexcept override
+  {
+    SpawnBackgroundWorkThread();
+    return true;
+  }
+
 private:
   void Initialize()
   {
@@ -1673,6 +1679,16 @@ opentelemetry::sdk::common::ExportResult OtlpFileClient::Export(
   return ::opentelemetry::sdk::common::ExportResult::kFailure;
 }
 
+bool OtlpFileClient::MaybeSpawnBackgroundThread() noexcept
+{
+  if (backend_)
+  {
+    return backend_->MaybeSpawnBackgroundThread();
+  }
+
+  return false;
+}
+
 bool OtlpFileClient::ForceFlush(std::chrono::microseconds timeout) noexcept
 {
